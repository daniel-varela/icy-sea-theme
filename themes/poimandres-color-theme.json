    "tokenColors": [
      {
        "scope": ["entity.name.type.class.cs", "variable.other.constant.js"],
        "settings": {
          "foreground": "#5DE4c7"
        }
      },
      {
        "scope": ["entity.name.type.cs", "entity.name.type.namespace.cs"],
        "settings": {
          "foreground": "#61b8a5"
        }
      },
      {
        "scope": ["entity.name", "variable.other"],
        "settings": {
          "foreground": "#e4f0fbda"
        }
      },
      {
        "scope": ["entity.name.function", "entity.name.function.js", "variable.other.object.property", "variable.other.property"],
        "settings": {
          "foreground": "#89ddff"
        }
      },
      {
        "scope": ["keyword.type"],
        "settings": {
          "foreground": "#61b8a5",
          "fontStyle": "bold"
        }
      },
      {
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": {
          "foreground": "#303340"
        }
      },
      {
        "scope": ["storage.modifier", "keyword", "keyword.other", "storage.type", "keyword.control"],
        "settings": {
          "foreground": "#7390AA"
        }
      },
      {
        "scope": ["string"],
        "settings": {
          "foreground": "#ADD7FF"
        }
      },
      {
        "scope": ["keyword.control.flow"],
        "settings": {
          "foreground": "#f087bd"
        }
      }
    ]
